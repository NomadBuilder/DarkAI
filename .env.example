# Get involved form → Google Apps Script web app URL (see ledger/GET_INVOLVED_GOOGLE_SHEET.md)
# On Render: set either name; Flask serves it at runtime via /api/protectont-config (no rebuild required).
# NEXT_PUBLIC_GET_INVOLVED_SUBMIT_URL=https://script.google.com/macros/s/XXXXXXXX/exec
# GET_INVOLVED_SUBMIT_URL=https://script.google.com/macros/s/XXXXXXXX/exec

# Email Configuration for Contact Form
# Option 1: Resend (Recommended - Free tier: 3,000 emails/month)
# Get your API key at: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxx
FROM_EMAIL=noreply@yourdomain.com
CONTACT_EMAIL=aazirmun@gmail.com

# Option 2: SMTP (Alternative - requires app password)
# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# CONTACT_EMAIL=aazirmun@gmail.com
